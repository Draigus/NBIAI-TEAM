# NBI Dashboard — Environment Configuration
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nbi_dashboard
ADMIN_DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# Server
PORT=8888
APP_URL=http://localhost:8888

# SMTP (optional — falls back to console logging if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nbi-consulting.com

# Session
SESSION_EXPIRY_DAYS=7

# Slack Bot (optional — Slack integration disabled when not set)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
QUEUE_API_KEY=generate-a-random-key-here
