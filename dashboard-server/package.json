{
  "name": "nbi-dashboard-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "init-db": "node init-db.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.js",
    "test:all": "npm run test && npm run test:e2e",
    "postinstall": "playwright install chromium --with-deps || true"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "dotenv": "^17.4.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "http-proxy-middleware": "^3.0.5",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
