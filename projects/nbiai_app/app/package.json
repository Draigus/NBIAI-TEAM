    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.36.0",
    "fastify": "^4.28.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
