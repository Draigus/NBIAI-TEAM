# Large binary files (exceed GitHub 100MB limit)
*.pptx
*.xlsx

# Queue task files (contain session prompts and agent output)
# The folder structure is tracked via .gitkeep files
# scripts/ and schedules/ subdirectories are version-controlled
queue/inbox/*.json
queue/active/*.json
queue/review/*.json
queue/done/*.json
queue/failed/*.json

# Environment files (contain secrets)
.env
.env.*
.env.local
.env.production
.env.test
.env.bak-*
dashboard-server/.env.*

# Test infrastructure
dashboard-server/tests/.tmp/
dashboard-server/tests/.coverage/
dashboard-server/test-results/
dashboard-server/playwright-report/

# Node.js
node_modules/

# Build output
dist/

# PM2 logs
logs/
*.log

# Database backups
dashboard-server/backups/

# Uploaded files
dashboard-server/uploads/

# Sensitive seed data (salaries, client details)
dashboard-server/finance-seed.json
dashboard-server/seed-data.csv

# Archive / migration backups
_archive/

# Claude Code installed skills and local config
.agents/skills/
.claude/skills/
.claude/reference-skills/
.claude/settings.json
.superpowers/
.mcp.json

# Debug and temp artifacts
_temp/
dashboard-server/cookies.txt
dashboard-server/cc-debug-screenshot.png
dashboard-server/cc-scroll-test-*.png
dashboard-server/cc-scroll-test.html
dashboard-server/public/cc-scroll-test.html
dashboard-server/_check_users.js

# Verification screenshots (temporary, not source material)
*.png

# Test output captures
e2e-output.txt
test-output.txt

# AI tooling directories
.codex/
.planning/
.playwright-mcp/
.claude/hooks/
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db
.worktrees/
.claude/worktrees/

# Generated knowledge graph indexes
graphify-out/
dashboard-server/graphify-out/
